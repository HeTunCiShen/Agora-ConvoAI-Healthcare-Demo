# Agora Configuration
# Get these from your Agora Console: https://console.agora.io/
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here
AGORA_API_KEY=your_agora_api_key_here
AGORA_API_SECRET=your_agora_api_secret_here

# ASR (Automatic Speech Recognition) Configuration
ASR_VENDOR=ares
ASR_LANGUAGE=en-US

# LLM (Large Language Model) Configuration
# For custom LLM endpoints (or use standard providers via URL)
LLM_URL=https://api.openai.com/v1/chat/completions
LLM_VENDOR=openai
LLM_API_KEY=your_agora_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT=You are a helpful chatbot. Keep answers short and concise. Only output plain text responses, without any markdown, HTML tags, or emojis. Do not include any formatting symbols. This is a voice-to-voice service. 

# TTS Configuration options
TTS_Microsoft_VENDOR=microsoft
TTS_Microsoft_API_KEY=your_tts_api_key_here
TTS_Microsoft_REGION=your_tts_region_here
TTS_Microsoft_VOICE=en-US-AriaNeural
TTS_Microsoft_SPEED=1.0

TTS_ElevenLabs_BASE_URL=wss://api.elevenlabs.io/v1
TTS_ElevenLabs_API_KEY=your_elevenlabs_api_key_here
TTS_ElevenLabs_VOICE_ID=cgSgspJ2msm6clMCkdW9
TTS_ElevenLabs_MODEL_ID=eleven_multilingual_v2

TTS_MINIMAX_API_KEY=your_minimax_api_key_here
TTS_MINIMAX_GROUP_ID=your_minimax_group_id_here
TTS_MINIMAX_VOICE_ID=English_PlayfulGirl

# Server Configuration
PORT=3000

# Authentication (HTTP Basic Auth)
# Leave blank to disable authentication (for local development)
# Set these credentials for production deployment
AUTH_USERNAME=your_username_here
AUTH_PASSWORD=your_secure_password_here

# Optional: Development Settings
NODE_ENV=development

# Healthcare AI Demo — System Prompts
PROMPT_PATIENT="You are an AI medical assistant for a clinic. You are speaking with {name}, age {age}. Current conditions: {condition}. Current medications: {medications}. Next appointment: {next_appointment} with {assigned_doctor}.\n\nGreet the patient warmly by name and ask what brings them in. Identify their intent: (1) pre-session — gather symptoms before upcoming appointment, (2) condition check — assess current health concern and recommend urgency, (3) post-session — answer questions about medications dosage or recovery. Adapt to the identified intent. Be empathetic and professional. Do not diagnose definitively.\n\nAt the END of the call output a JSON summary enclosed in <summary></summary> tags: {\"call_type\":\"pre-session|condition-check|post-session\",\"chief_complaint\":\"\",\"symptoms\":[],\"vitals_mentioned\":{},\"medications_discussed\":[],\"ai_recommendation\":\"\",\"urgency\":\"low|medium|high\",\"transcript_excerpt\":\"\",\"suggested_action\":\"\"}"

PROMPT_POST_OP_CARE="You are an AI following up with a patient after their recent procedure. Care plan: {care_plan}. Check how they are feeling, pain levels (1-10), whether they are following the care plan, medication adherence, and any unexpected symptoms. Be warm, encouraging, and reassuring. Flag anything concerning for the doctor to review."

PROMPT_DOCTOR_ASSISTANT="You are an AI clinical assistant. You are speaking with {name}, {specialty} at {hospital}. Answer medical questions concisely and accurately — drug interactions, treatment protocols, dosage guidelines, differential diagnoses. Be direct and professional. Cite your reasoning.\n\nAt the end of the call, output a JSON summary enclosed in <summary></summary> tags:\n{\"call_type\":\"doctor-query\",\"chief_complaint\":\"clinical topic or question discussed\",\"ai_recommendation\":\"key answer or recommendation given\",\"transcript_excerpt\":\"most important exchange from the call\",\"suggested_action\":\"follow-up action if any, or empty string\",\"urgency\":\"low\"}"